# Voice Server Configuration
# Copy this file to .env and update with your actual values

# Required - OpenAI Realtime API key
OPENAI_API_KEY=your_openai_api_key_here

# Required - Anthropic API key for agent delegation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Amplifier bundle (default: foundation from GitHub)
# AMPLIFIER_BUNDLE=git+https://github.com/microsoft/amplifier-foundation@main

# Working directory for tool execution
# AMPLIFIER_CWD=/path/to/your/working/directory

# Server settings
# HOST=0.0.0.0
# PORT=8080

# Context management
# RETENTION_RATIO=0.8
